# ── JMD Promotions — Environment Variables ────────────────────────────────────
# Copy this to .env for local dev, or set these in Coolify's environment panel.

# Django
SECRET_KEY=your-very-long-random-secret-key-change-this
DEBUG=False

# Hosts — add your domain when you have one e.g. jmdpromotions.co.za
ALLOWED_HOSTS=127.0.0.1,localhost,51.255.1.140
CSRF_TRUSTED_ORIGINS=http://51.255.1.140,https://51.255.1.140

# ── PostgreSQL (shared Coolify PostgreSQL service) ────────────────────────────
# In Coolify: Resources → PostgreSQL → copy connection details here
DB_NAME=jmd_db
DB_USER=jmd_user
DB_PASSWORD=your-strong-db-password
DB_HOST=your-coolify-postgres-host    # e.g. postgresql.coolify.internal or the service name
DB_PORT=5432

# ── Admin superuser (auto-created on first deploy by entrypoint.sh) ───────────
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_PASSWORD=change-this-password
DJANGO_SUPERUSER_EMAIL=admin@jmdpromotions.co.za

# ── Gunicorn tuning ───────────────────────────────────────────────────────────
GUNICORN_WORKERS=3
GUNICORN_TIMEOUT=120

# ── Email (optional — leave blank to use console backend) ────────────────────
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=noreply@jmdpromotions.co.za
